<Page
    x:Class="SIV.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:SIV.App.Converters">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="8">
            <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                    ToolTipService.ToolTip="Back" Padding="8,4"
                    Command="{x:Bind ViewModel.GoBackCommand}" />
            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>

        <NavigationView x:Name="SettingsNav" Grid.Row="1"
                        PaneDisplayMode="Left"
                        OpenPaneLength="220"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="SettingsNav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="General" Tag="General" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE771;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Pricing" Tag="Pricing">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Game" Tag="Game">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7FC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="About" Tag="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="36,8,36,24" MaxWidth="700" HorizontalAlignment="Left">

                        <StackPanel x:Name="GeneralSection" Spacing="4">
                            <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" Margin="1,8,0,16" />

                            <controls:SettingsCard Header="Theme"
                                                   Description="Choose app appearance">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE771;" />
                                </controls:SettingsCard.HeaderIcon>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}" MinWidth="140">
                                    <ComboBoxItem Content="Dark" />
                                    <ComboBoxItem Content="Light" />
                                    <ComboBoxItem Content="System" />
                                </ComboBox>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Open Market Links In"
                                                   Description="Choose where to open Steam Market links">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE71B;" />
                                </controls:SettingsCard.HeaderIcon>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedOpenLinkInIndex, Mode=TwoWay}" MinWidth="140">
                                    <ComboBoxItem Content="Steam App" />
                                    <ComboBoxItem Content="Browser" />
                                </ComboBox>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Cache Icons Locally"
                                                   Description="Save item icons to disk so they load instantly on next launch">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </controls:SettingsCard.HeaderIcon>
                                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableIconCache, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <TextBlock Text="Updates" Style="{StaticResource SubtitleTextBlockStyle}" Margin="1,24,0,16" />

                            <controls:SettingsCard Header="Show Update Button"
                                                   Description="Display the update button in the title bar when a new version is available">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE896;" />
                                </controls:SettingsCard.HeaderIcon>
                                <ToggleSwitch IsOn="{x:Bind ViewModel.ShowUpdateButton, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <InfoBar x:Name="UpdateInfoBar" IsOpen="True" IsClosable="False" Margin="0,4,0,0">
                                <InfoBar.Content>
                                    <StackPanel Spacing="4" Margin="0,0,0,12">
                                        <TextBlock>
                                            <Run Text="Current version:" />
                                            <Run Text="{x:Bind ViewModel.CurrentVersion}" FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Text="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}" />
                                    </StackPanel>
                                </InfoBar.Content>
                            </InfoBar>
                        </StackPanel>

                        <StackPanel x:Name="PricingSection" Spacing="4" Visibility="Collapsed">
                            <TextBlock Text="Pricing" Style="{StaticResource SubtitleTextBlockStyle}" Margin="1,8,0,16" />

                            <controls:SettingsCard Header="Price Cache Duration"
                                                   Description="How long cached prices remain valid (hours)">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE823;" />
                                </controls:SettingsCard.HeaderIcon>
                                <NumberBox Value="{x:Bind ViewModel.PriceCacheDurationHours, Mode=TwoWay}"
                                           Minimum="1" Maximum="168" SpinButtonPlacementMode="Compact" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Request Delay (ms)"
                                                   Description="Delay between price requests to Steam Market">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE916;" />
                                </controls:SettingsCard.HeaderIcon>
                                <NumberBox Value="{x:Bind ViewModel.PriceRequestDelayMs, Mode=TwoWay}"
                                           Minimum="500" Maximum="30000" SpinButtonPlacementMode="Compact"
                                           SmallChange="500" LargeChange="1000" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Max Consecutive Failures"
                                                   Description="Stop fetching prices after this many consecutive failed requests">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE7BA;" />
                                </controls:SettingsCard.HeaderIcon>
                                <NumberBox Value="{x:Bind ViewModel.PriceMaxConsecutiveFailures, Mode=TwoWay}"
                                           Minimum="1" Maximum="20" SpinButtonPlacementMode="Compact" />
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Retry Delay (seconds)"
                                                   Description="Wait time before retrying after a failed request">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE895;" />
                                </controls:SettingsCard.HeaderIcon>
                                <NumberBox Value="{x:Bind ViewModel.PriceRetryDelaySeconds, Mode=TwoWay}"
                                           Minimum="1" Maximum="120" SpinButtonPlacementMode="Compact" />
                            </controls:SettingsCard>
                        </StackPanel>

                        <StackPanel x:Name="GameSection" Spacing="4" Visibility="Collapsed">
                            <TextBlock Text="Game" Style="{StaticResource SubtitleTextBlockStyle}" Margin="1,8,0,16" />

                            <controls:SettingsCard Header="CS2 Game Path"
                                                   Description="Path to CS2 install folder for skin names and icons">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE838;" />
                                </controls:SettingsCard.HeaderIcon>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBox Text="{x:Bind ViewModel.Cs2GamePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="300" PlaceholderText="C:\Program Files (x86)\Steam\steamapps\common\Counter-Strike Global Offensive" />
                                    <Button Content="Browse..." Click="BrowseCs2Path_Click" />
                                </StackPanel>
                            </controls:SettingsCard>
                            <InfoBar x:Name="Cs2PathInfoBar"
                                     IsOpen="{x:Bind ViewModel.HasCs2PathStatus, Mode=OneWay}"
                                     IsClosable="False"
                                     Message="{x:Bind ViewModel.Cs2PathStatus, Mode=OneWay}"
                                     Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel x:Name="AboutSection" Spacing="4" Visibility="Collapsed">
                            <TextBlock Text="About" Style="{StaticResource SubtitleTextBlockStyle}" Margin="1,8,0,16" />

                            <controls:SettingsCard Header="SIV — Steam Inventory Viewer"
                                                   Description="{x:Bind ViewModel.VersionDescription}">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE946;" />
                                </controls:SettingsCard.HeaderIcon>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="Source Code"
                                                   Description="View the project on GitHub"
                                                   IsClickEnabled="True"
                                                   Click="OpenGitHub_Click">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE943;" />
                                </controls:SettingsCard.HeaderIcon>
                            </controls:SettingsCard>

                            <controls:SettingsCard Header="App Data"
                                                   Description="Open the local data folder"
                                                   IsClickEnabled="True"
                                                   Click="OpenDataFolder_Click">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE838;" />
                                </controls:SettingsCard.HeaderIcon>
                            </controls:SettingsCard>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" x:Name="ActionBar"
                        Padding="36,12"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid MaxWidth="700" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save" Command="{x:Bind ViewModel.SaveCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Reset" Command="{x:Bind ViewModel.ResetCommand}" />
                            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                       Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
