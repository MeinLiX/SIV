<Page
    x:Name="RootPage"
    x:Class="SIV.App.Pages.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SIV.UI.ViewModels"
    xmlns:entities="using:SIV.Domain.Entities"
    xmlns:converters="using:SIV.App.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NullToVisibilityConverter x:Key="InverseNullToVis" Invert="True" />
        <converters:DecimalFormatConverter x:Key="DecimalFormat" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSource" />
        <converters:HexStringToBrushConverter x:Key="HexToBrush" />
        <converters:HexToRadialGlowBrushConverter x:Key="HexToGlow" />
        <Style x:Key="InventoryPreviewPrimaryCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="InventoryPreviewSideCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="InventoryPreviewCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.68" />
        </Style>
        <Style x:Key="InventoryPreviewChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
        </Style>
        <DataTemplate x:Key="InventoryHoverPreviewTemplate" x:DataType="vm:InventoryItemViewModel">
            <Border Width="360" Style="{StaticResource InventoryPreviewPrimaryCardStyle}">
                <StackPanel Spacing="14">
                    <Border Height="248" CornerRadius="12"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Image Source="{x:Bind LargeIconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                               Stretch="Uniform"
                               Margin="10" />
                    </Border>

                    <StackPanel Spacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="Bold" FontSize="18"
                                       TextWrapping="WrapWholeWords" MaxLines="3" />
                            <TextBlock Text="{x:Bind CustomName, Mode=OneWay}" FontStyle="Italic" FontSize="13"
                                       Opacity="0.72"
                                       Visibility="{x:Bind HasCustomName, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Style="{StaticResource InventoryPreviewChipStyle}">
                                <TextBlock Text="{x:Bind RarityDisplayName}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                            </Border>
                            <Border Style="{StaticResource InventoryPreviewChipStyle}"
                                    Visibility="{x:Bind HasSpecialQuality, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{x:Bind QualityDisplayName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{x:Bind QualityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                            </Border>
                            <Border Style="{StaticResource InventoryPreviewChipStyle}"
                                    Visibility="{x:Bind HasExterior, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{x:Bind ExteriorDisplayName, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{x:Bind ExteriorColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                            </Border>
                        </StackPanel>

                        <Border CornerRadius="12" Padding="12"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                Visibility="{x:Bind HasFloat, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Finish" Style="{StaticResource InventoryPreviewCaptionStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="14">
                                    <TextBlock FontSize="13">
                                        <Run Text="Float " FontWeight="SemiBold" />
                                        <Run Text="{x:Bind FloatDisplayName, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock FontSize="13"
                                               Visibility="{x:Bind HasPattern, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                        <Run Text="Pattern " FontWeight="SemiBold" />
                                        <Run Text="{x:Bind PatternDisplayName, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="{x:Bind SkinDisplayName, Mode=OneWay}" FontSize="12" Opacity="0.72"
                                           TextWrapping="WrapWholeWords"
                                           Visibility="{x:Bind HasSkin, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Status" Style="{StaticResource InventoryPreviewCaptionStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock FontSize="12" Opacity="0.72" Text="{x:Bind TradableStatusText}" />
                                <TextBlock FontSize="12" Opacity="0.72" Text="{x:Bind MarketableStatusText}" />
                            </StackPanel>
                            <TextBlock FontSize="13" Foreground="#FF9800"
                                       Visibility="{x:Bind HasTradeLockRemaining, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Run Text="&#x1F512; Trade Lock " FontWeight="SemiBold" />
                                <Run Text="{x:Bind TradeLockRemainingText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#9C27B0"
                                       Visibility="{x:Bind IsGraffiti, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Run Text="Sprays " FontWeight="SemiBold" />
                                <Run Text="{x:Bind GraffitiUsesText, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock FontSize="13"
                                       Visibility="{x:Bind HasCasketItems, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <Run Text="Storage " FontWeight="SemiBold" />
                                <Run Text="{x:Bind CasketItemCountDisplay, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind HasStickers, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Attached summary" Style="{StaticResource InventoryPreviewCaptionStyle}" />
                            <TextBlock Text="{x:Bind StickersSummary, Mode=OneWay}" FontSize="12"
                                       TextWrapping="WrapWholeWords" Opacity="0.78" />
                        </StackPanel>

                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind HasKeychain, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Keychain" Style="{StaticResource InventoryPreviewCaptionStyle}" />
                            <TextBlock Text="{x:Bind KeychainSummary, Mode=OneWay}" FontSize="12" Opacity="0.78"
                                       TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2"
                                        Visibility="{x:Bind HasPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Market price" Style="{StaticResource InventoryPreviewCaptionStyle}" />
                                <TextBlock Text="{x:Bind PriceDisplayText, Mode=OneWay}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>

                            <Border Grid.Column="1" CornerRadius="999" Padding="10,5"
                                    HorizontalAlignment="Right"
                                    Background="{x:Bind OriginBadgeColor, Converter={StaticResource HexToBrush}}"
                                    Visibility="{x:Bind HasOriginBadge, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{x:Bind OriginDisplayName}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InventoryAppliedPopupTemplate" x:DataType="vm:InventoryItemViewModel">
            <Border Width="420" Style="{StaticResource InventoryPreviewSideCardStyle}">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Applied" FontSize="14" FontWeight="SemiBold" />
                        <Border Grid.Column="1" Style="{StaticResource InventoryPreviewChipStyle}">
                            <TextBlock Text="{x:Bind StickerCards.Count, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="220">
                        <ItemsControl ItemsSource="{x:Bind StickerCards, Mode=OneWay}"
                                      ItemTemplate="{StaticResource InventoryStickerCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InventoryOriginsPopupTemplate" x:DataType="vm:InventoryItemViewModel">
            <Border Width="420" Style="{StaticResource InventoryPreviewSideCardStyle}">
                <StackPanel Spacing="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Drops from" FontSize="14" FontWeight="SemiBold" />
                        <Border Grid.Column="1" Style="{StaticResource InventoryPreviewChipStyle}">
                            <TextBlock Text="{x:Bind Origins.Count, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="240">
                        <ItemsControl ItemsSource="{x:Bind Origins, Mode=OneWay}"
                                      ItemTemplate="{StaticResource InventoryOriginCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapGrid Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InventoryStickerCardTemplate" x:DataType="entities:StickerCardInfo">
            <Border Width="96" Margin="0,0,8,8" Padding="8"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <Border Width="68" Height="68" CornerRadius="10"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid>
                            <Image Source="{x:Bind IconUrl, Converter={StaticResource StringToImageSource}}"
                                   Stretch="Uniform"
                                   Margin="6"
                                   Visibility="{x:Bind IconUrl, Converter={StaticResource NullToVis}}" />
                            <FontIcon Glyph="&#xE91B;" FontSize="28" Opacity="0.28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind IconUrl, Converter={StaticResource InverseNullToVis}}" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{x:Bind Name}" FontSize="11" FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords" TextAlignment="Center"
                               MaxLines="3" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InventoryOriginCardTemplate" x:DataType="entities:ItemOriginInfo">
            <Border Width="108" Margin="0,0,8,8" Padding="8"
                    CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <Border Width="68" Height="68" CornerRadius="10"
                            HorizontalAlignment="Center"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                        <Grid>
                            <Image Source="{x:Bind IconUrl, Converter={StaticResource StringToImageSource}}"
                                   Stretch="Uniform"
                                   Margin="6"
                                   Visibility="{x:Bind IconUrl, Converter={StaticResource NullToVis}}" />
                            <FontIcon Glyph="&#xE91B;" FontSize="28" Opacity="0.28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{x:Bind IconUrl, Converter={StaticResource InverseNullToVis}}" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{x:Bind Name}" FontSize="11" FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords" TextAlignment="Center"
                               MaxLines="3" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{x:Bind TypeDisplayName}" FontSize="10" Opacity="0.58"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsOpen="False">
            <AppBarButton Label="Refresh Inventory" Icon="Refresh"
                          Command="{x:Bind ViewModel.LoadInventoryCommand}"
                          Visibility="{x:Bind ViewModel.HasLoadedOnce, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            <AppBarButton Label="Fetch Prices" Icon="Shop"
                          Command="{x:Bind ViewModel.FetchPricesCommand}"
                          Visibility="{x:Bind ViewModel.HasLoadedOnce, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            <AppBarToggleButton Label="Group Items" Icon="Sort"
                                IsChecked="{x:Bind ViewModel.IsGrouped, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.HasLoadedOnce, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            <AppBarToggleButton Label="Hide Non-Marketable" Icon="Filter"
                                IsChecked="{x:Bind ViewModel.HideNonMarketable, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.HasLoadedOnce, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
        </CommandBar>

        <Grid Grid.Row="1" Margin="16,8,16,4" ColumnSpacing="12"
              Visibility="{x:Bind ViewModel.HasLoadedOnce, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox Grid.Column="0" Width="320"
                            PlaceholderText="Search inventory"
                            QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Sort" VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox ItemsSource="{x:Bind ViewModel.Sort.Options}"
                          SelectedItem="{x:Bind ViewModel.Sort.SelectedOption, Mode=TwoWay}"
                          MinWidth="120" VerticalAlignment="Center" />
                <Button Command="{x:Bind ViewModel.ToggleSortDirectionCommand}"
                        Padding="8,6" VerticalAlignment="Center"
                        ToolTipService.ToolTip="Toggle sort direction">
                    <FontIcon Glyph="{x:Bind ViewModel.Sort.DirectionGlyph, Mode=OneWay}" FontSize="12" />
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Type" VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox MinWidth="170"
                          ItemsSource="{x:Bind ViewModel.AvailableTypes, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedTypeFilter, Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Margin="16,4"
                    Visibility="{x:Bind ViewModel.ShowToolbarLoadingState, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" />
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Opacity="0.7" Margin="0,4"
                       Visibility="{x:Bind ViewModel.ShowToolbarStatusText, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <InfoBar Grid.Row="2" Severity="Error" IsClosable="True"
                 Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" IsOpen="True" Margin="16,4" />

        <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                  Padding="8,0" SelectionMode="None"
                  Visibility="{x:Bind ViewModel.IsGrouped, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:InventoryItemViewModel">
                    <Grid Padding="8,6" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="80" Height="80" CornerRadius="6"
                                BorderBrush="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                BorderThickness="2"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                PointerEntered="InventoryItem_PointerEntered"
                                PointerMoved="InventoryItem_PointerMoved"
                                PointerExited="InventoryItem_PointerExited">
                            <Grid>
                                <Border CornerRadius="4"
                                        Background="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToGlow}}" />
                                <Image Source="{x:Bind IconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                                       Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                                <FontIcon Glyph="&#xE72E;" FontSize="12" Opacity="0.6"
                                          ToolTipService.ToolTip="Temporary trade lock"
                                          Visibility="{x:Bind IsTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind TradeLockRemainingText, Mode=OneWay}" FontSize="11" Foreground="#FF9800"
                                           Visibility="{x:Bind HasTradeLockRemaining, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind GraffitiUsesText, Mode=OneWay}" FontSize="11" Opacity="0.5"
                                           Visibility="{x:Bind IsGraffiti, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind QualityDisplayName, Mode=OneWay}"
                                           Foreground="{x:Bind QualityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                           FontSize="12" VerticalAlignment="Center"
                                           Visibility="{x:Bind HasSpecialQuality, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind CustomName, Mode=OneWay}" FontSize="12" FontStyle="Italic"
                                       Opacity="0.7" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasCustomName, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.7">
                                <TextBlock Text="{x:Bind ExteriorDisplayName}" FontSize="12"
                                           Foreground="{x:Bind ExteriorColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                           Visibility="{x:Bind HasExterior, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind RarityDisplayName}"
                                           Foreground="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                           FontSize="12" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12" Opacity="0.7"
                                        Visibility="{x:Bind HasFloat, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11">
                                    <Run Text="Float: " FontWeight="SemiBold" /><Run Text="{x:Bind FloatDisplayName, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Visibility="{x:Bind HasPattern, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <Run Text="Pattern: " FontWeight="SemiBold" /><Run Text="{x:Bind PatternDisplayName, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="{x:Bind StickersSummary, Mode=OneWay}" Opacity="0.6"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasStickers, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{x:Bind KeychainSummary, Mode=OneWay}" Opacity="0.6"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasKeychain, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Orientation="Horizontal" Spacing="4">
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                                       Text="{x:Bind PriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       ToolTipService.ToolTip="{x:Bind PriceUpdatedAtText, Mode=OneWay}" />
                            <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    ToolTipService.ToolTip="Refresh Price" Padding="4,2"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RefreshItemPriceCommand}"
                                    CommandParameter="{Binding}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <Button Content="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    ToolTipService.ToolTip="Steam Market" Padding="4,2"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.OpenMarketListingCommand}"
                                    CommandParameter="{x:Bind MarketHashName}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <ProgressRing IsActive="{x:Bind IsRefreshingPrice, Mode=OneWay}" Width="16" Height="16"
                                          Visibility="{x:Bind IsRefreshingPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind CasketTotalPriceDisplay, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"
                                       ToolTipService.ToolTip="Storage unit contents value"
                                       Visibility="{x:Bind HasCasketTotalPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{x:Bind CasketItemCountDisplay, Mode=OneWay}" FontSize="12" Opacity="0.7"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind HasCasketItems, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <Button Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                    ToolTipService.ToolTip="Open Casket"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.OpenCasketItemCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsCasket, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.FilteredGroups, Mode=OneWay}"
                  Padding="8,0" SelectionMode="None"
                  Visibility="{x:Bind ViewModel.IsGrouped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:InventoryGroupViewModel">
                    <Grid Padding="8,6" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="80" Height="80" CornerRadius="6"
                                BorderBrush="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                BorderThickness="2"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Grid>
                                <Border CornerRadius="4"
                                        Background="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToGlow}}" />
                                <Image Source="{x:Bind IconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                                       Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                                <FontIcon Glyph="&#xE72E;" FontSize="12" Opacity="0.6"
                                          ToolTipService.ToolTip="Temporary trade lock"
                                          Visibility="{x:Bind HasTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind TradeLockExpiresText, Mode=OneWay}" FontSize="11" Opacity="0.5"
                                           Visibility="{x:Bind HasTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind GraffitiUsesText, Mode=OneWay}" FontSize="11" Opacity="0.5"
                                           Visibility="{x:Bind IsGraffiti, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind CountDisplay, Mode=OneWay}" Opacity="0.7" FontSize="12" />
                                <TextBlock Text="{x:Bind CasketTotalPriceDisplay, Mode=OneWay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemAccentColor}"
                                           ToolTipService.ToolTip="Storage unit contents value"
                                           Visibility="{x:Bind HasCasketTotalPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Bind UnitPriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       HorizontalAlignment="Right" Opacity="0.7" FontSize="12" />
                            <TextBlock Text="{x:Bind TotalPriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       HorizontalAlignment="Right" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal" Spacing="4">
                            <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    ToolTipService.ToolTip="Refresh Price" Padding="4,2"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.RefreshGroupPriceCommand}"
                                    CommandParameter="{Binding}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <Button Content="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                    ToolTipService.ToolTip="Steam Market" Padding="4,2"
                                    Command="{Binding ElementName=RootPage, Path=ViewModel.OpenMarketListingCommand}"
                                    CommandParameter="{x:Bind MarketHashName}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <ProgressRing IsActive="{x:Bind IsRefreshingPrice, Mode=OneWay}" Width="16" Height="16"
                                          Visibility="{x:Bind IsRefreshingPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Button Grid.Column="4" Content="Details"
                                Command="{Binding ElementName=RootPage, Path=ViewModel.OpenGroupDetailsCommand}"
                                CommandParameter="{Binding}" VerticalAlignment="Center" />

                        <Button Grid.Column="5" Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                ToolTipService.ToolTip="Open Casket"
                                Command="{Binding ElementName=RootPage, Path=ViewModel.OpenCasketCommand}"
                                CommandParameter="{Binding}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind IsCasketGroup, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16"
                    Visibility="{x:Bind ViewModel.ShowInitialLoadCta, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <FontIcon Glyph="&#xE896;" FontSize="48" Opacity="0.4" HorizontalAlignment="Center" />
            <TextBlock Text="No inventory loaded" FontSize="16" Opacity="0.5" HorizontalAlignment="Center" />
            <Button Content="Load Inventory" Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Center" Padding="24,10"
                    Command="{x:Bind ViewModel.LoadInventoryCommand}" />
        </StackPanel>

        <Grid Grid.Row="3"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.ShowInitialLoadingIndicator, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <ProgressRing IsActive="True"
                          Width="48"
                          Height="48"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="4" Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24">
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Items: " FontWeight="SemiBold" />
                        <Run Text="{x:Bind ViewModel.PriceSummary.ItemCountDisplay, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="Priced: " FontWeight="SemiBold" />
                        <Run Text="{x:Bind ViewModel.PriceSummary.PricedItems, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                           Text="{x:Bind ViewModel.PriceSummary.TotalValueFormatted, Mode=OneWay}" />
            </Grid>
        </Border>

    </Grid>
</Page>
