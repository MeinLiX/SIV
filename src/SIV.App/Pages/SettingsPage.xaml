<Page
    x:Class="SIV.App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:SIV.App.Converters">

    <Page.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" HorizontalAlignment="Center" Spacing="4" Padding="24">

            <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" />

            <controls:SettingsCard Header="Price Cache Duration"
                                   Description="How long cached prices remain valid (hours)">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE823;" />
                </controls:SettingsCard.HeaderIcon>
                <NumberBox Value="{x:Bind ViewModel.PriceCacheDurationHours, Mode=TwoWay}"
                           Minimum="1" Maximum="168" SpinButtonPlacementMode="Compact" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Request Delay (ms)"
                                   Description="Delay between price requests to Steam Market">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE916;" />
                </controls:SettingsCard.HeaderIcon>
                <NumberBox Value="{x:Bind ViewModel.PriceRequestDelayMs, Mode=TwoWay}"
                           Minimum="500" Maximum="30000" SpinButtonPlacementMode="Compact"
                           SmallChange="500" LargeChange="1000" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Max Consecutive Failures"
                                   Description="Stop fetching prices after this many consecutive failed requests">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7BA;" />
                </controls:SettingsCard.HeaderIcon>
                <NumberBox Value="{x:Bind ViewModel.PriceMaxConsecutiveFailures, Mode=TwoWay}"
                           Minimum="1" Maximum="20" SpinButtonPlacementMode="Compact" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Retry Delay (seconds)"
                                   Description="Wait time before retrying after a failed request">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;" />
                </controls:SettingsCard.HeaderIcon>
                <NumberBox Value="{x:Bind ViewModel.PriceRetryDelaySeconds, Mode=TwoWay}"
                           Minimum="1" Maximum="120" SpinButtonPlacementMode="Compact" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="Theme"
                                   Description="Choose app appearance">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE771;" />
                </controls:SettingsCard.HeaderIcon>
                <ComboBox SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}" MinWidth="120">
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="System" />
                </ComboBox>
            </controls:SettingsCard>

            <controls:SettingsCard Header="Cache Icons Locally"
                                   Description="Save item icons to disk so they load instantly on next launch">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;" />
                </controls:SettingsCard.HeaderIcon>
                <ToggleSwitch IsOn="{x:Bind ViewModel.EnableIconCache, Mode=TwoWay}" />
            </controls:SettingsCard>

            <controls:SettingsCard Header="CS2 Game Path"
                                   Description="Path to CS2 install folder for skin names and icons">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE838;" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.Cs2GamePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="300" PlaceholderText="C:\Program Files (x86)\Steam\steamapps\common\Counter-Strike Global Offensive" />
                    <Button Content="Browse..." Click="BrowseCs2Path_Click" />
                </StackPanel>
            </controls:SettingsCard>
            <TextBlock Text="{x:Bind ViewModel.Cs2PathStatus, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="12" Margin="48,0,0,0" />

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,24,0,0">
                <Button Content="Save" Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Reset" Command="{x:Bind ViewModel.ResetCommand}" />
            </StackPanel>

            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay, Converter={StaticResource NullToVis}}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="0,8" />

            <Border Margin="0,24,0,0" Padding="12" CornerRadius="4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        <Run Text="Version" />
                        <Run Text="{x:Bind ViewModel.CurrentVersion}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
