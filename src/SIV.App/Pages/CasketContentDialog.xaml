<ContentDialog
    x:Name="RootDialog"
    x:Class="SIV.App.Pages.CasketContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SIV.UI.ViewModels"
    xmlns:converters="using:SIV.App.Converters"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertBoolToVis" Invert="True" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSource" />
        <converters:HexStringToBrushConverter x:Key="HexToBrush" />
        <converters:DecimalFormatConverter x:Key="DecimalFormat" />
    </ContentDialog.Resources>

    <Grid MinWidth="600" MinHeight="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Opacity="0.7" VerticalAlignment="Center" FontSize="13">
                <Run Text="{x:Bind ViewModel.TotalItemCount, Mode=OneWay}" />
                <Run Text=" items" />
            </TextBlock>
            <Button Grid.Column="1" Content="Fetch Prices" Padding="8,4" FontSize="12"
                    Command="{x:Bind ViewModel.FetchPricesCommand}" VerticalAlignment="Center" />
            <Button Grid.Column="2" Content="Refresh Storage" Padding="8,4" FontSize="12"
                    Command="{x:Bind ViewModel.RefreshStorageCommand}" VerticalAlignment="Center" />
            <AutoSuggestBox Grid.Column="3" PlaceholderText="Search..." QueryIcon="Find"
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Content="Name" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Name" Padding="6,3" FontSize="12" />
                <Button Content="Rarity" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Rarity" Padding="6,3" FontSize="12" />
                <Button Content="Type" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Type" Padding="6,3" FontSize="12" />
                <Button Content="Qty" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Quantity" Padding="6,3" FontSize="12" />
                <Button Content="Price" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Price" Padding="6,3" FontSize="12" />
                <Button Content="Float" Command="{x:Bind ViewModel.ToggleSortCommand}" CommandParameter="Float" Padding="6,3" FontSize="12" />
                <TextBlock Text="{x:Bind ViewModel.Sort.DisplayText, Mode=OneWay}" VerticalAlignment="Center"
                           Opacity="0.6" FontSize="11" Margin="4,0,0,0" />
            </StackPanel>
            <ToggleSwitch Grid.Column="5" OnContent="Grouped" OffContent="List"
                          IsOn="{x:Bind ViewModel.IsGrouped, Mode=TwoWay}"
                          VerticalAlignment="Center" MinWidth="0" />
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,4" Spacing="6">
            <InfoBar Severity="Error" IsClosable="True" IsOpen="True"
                     Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVis}}"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
            <ProgressBar Maximum="{x:Bind ViewModel.PricingTotal, Mode=OneWay}"
                         Value="{x:Bind ViewModel.PricingProgress, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.IsPricingRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                  SelectionMode="None" MaxHeight="500"
                  Visibility="{x:Bind ViewModel.IsGrouped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:InventoryGroupViewModel">
                    <Grid Padding="4,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" CornerRadius="2"
                                Background="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Image Source="{x:Bind IconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" FontSize="13" />
                            <FontIcon Glyph="&#xE72E;" FontSize="11" Opacity="0.6"
                                      ToolTipService.ToolTip="Temporary trade lock"
                                      Visibility="{x:Bind HasTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{x:Bind TradeLockExpiresText, Mode=OneWay}" FontSize="10" Opacity="0.5"
                                       Visibility="{x:Bind HasTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{x:Bind GraffitiUsesText, Mode=OneWay}" FontSize="10" Opacity="0.5"
                                       Visibility="{x:Bind IsGraffiti, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="{x:Bind UnitPriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       HorizontalAlignment="Right" Opacity="0.7" FontSize="11" />
                            <TextBlock Text="{x:Bind TotalPriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="12" />
                        </StackPanel>
                        <Border Grid.Column="4" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                CornerRadius="10" Padding="6,2" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Count, Mode=OneWay}" FontSize="11" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Button Grid.Column="5" Content="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                ToolTipService.ToolTip="Steam Market" Padding="4,2"
                                Command="{Binding ElementName=RootDialog, Path=ViewModel.OpenMarketListingCommand}"
                                CommandParameter="{x:Bind MarketHashName}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                  SelectionMode="None" MaxHeight="500"
                  Visibility="{x:Bind ViewModel.IsGrouped, Mode=OneWay, Converter={StaticResource InvertBoolToVis}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:InventoryItemViewModel">
                    <Grid Padding="4,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="4" CornerRadius="2"
                                Background="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}" />
                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="4"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                            <Image Source="{x:Bind IconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                                   Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" FontSize="13" />
                                <FontIcon Glyph="&#xE72E;" FontSize="11" Opacity="0.6"
                                          ToolTipService.ToolTip="Temporary trade lock"
                                          Visibility="{x:Bind IsTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind TradeLockExpiresText, Mode=OneWay}" FontSize="10" Opacity="0.5"
                                           Visibility="{x:Bind IsTemporaryTradeLock, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind GraffitiUsesText, Mode=OneWay}" FontSize="10" Opacity="0.5"
                                           Visibility="{x:Bind IsGraffiti, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                <TextBlock Text="{x:Bind QualityDisplayName, Mode=OneWay}"
                                           Foreground="{x:Bind QualityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Visibility="{x:Bind HasSpecialQuality, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind CustomName, Mode=OneWay}" FontSize="11" FontStyle="Italic"
                                       Opacity="0.7" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasCustomName, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.7">
                                <TextBlock Text="{x:Bind RarityDisplayName}"
                                           Foreground="{x:Bind RarityColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"
                                           FontSize="11" />
                                <TextBlock Text="{x:Bind ExteriorDisplayName}" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10" Opacity="0.7"
                                        Visibility="{x:Bind HasFloat, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="10">
                                    <Run Text="Float: " FontWeight="SemiBold" /><Run Text="{x:Bind FloatDisplayName, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock FontSize="10"
                                           Visibility="{x:Bind HasPattern, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <Run Text="Pattern: " FontWeight="SemiBold" /><Run Text="{x:Bind PatternDisplayName, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="{x:Bind StickersSummary, Mode=OneWay}" Opacity="0.6"
                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasStickers, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{x:Bind KeychainSummary, Mode=OneWay}" Opacity="0.6"
                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                       Visibility="{x:Bind HasKeychain, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Orientation="Horizontal" Spacing="4">
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12"
                                       Text="{x:Bind PriceUsd, Mode=OneWay, Converter={StaticResource DecimalFormat}}"
                                       ToolTipService.ToolTip="{x:Bind PriceUpdatedAtText, Mode=OneWay}" />
                            <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                    ToolTipService.ToolTip="Refresh Price" Padding="4,2"
                                    Command="{Binding ElementName=RootDialog, Path=ViewModel.RefreshItemPriceCommand}"
                                    CommandParameter="{Binding}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <Button Content="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                    ToolTipService.ToolTip="Steam Market" Padding="4,2"
                                    Command="{Binding ElementName=RootDialog, Path=ViewModel.OpenMarketListingCommand}"
                                    CommandParameter="{x:Bind MarketHashName}"
                                    Visibility="{x:Bind CanFetchPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            <ProgressRing IsActive="{x:Bind IsRefreshingPrice, Mode=OneWay}" Width="14" Height="14"
                                          Visibility="{x:Bind IsRefreshingPrice, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.ShowLoadingOverlay, Mode=OneWay, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ProgressRing IsActive="True" Width="40" Height="40" />
                <TextBlock Text="Loading storage..." HorizontalAlignment="Center" Opacity="0.72" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <TextBlock VerticalAlignment="Center" FontSize="12">
                        <Run Text="Items: " FontWeight="SemiBold" />
                        <Run Text="{x:Bind ViewModel.PriceSummary.TotalItems, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center" FontSize="12">
                        <Run Text="Priced: " FontWeight="SemiBold" />
                        <Run Text="{x:Bind ViewModel.PriceSummary.PricedItems, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"
                           Text="{x:Bind ViewModel.PriceSummary.TotalValueFormatted, Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</ContentDialog>
