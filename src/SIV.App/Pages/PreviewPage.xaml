<Page
    x:Class="SIV.App.Pages.PreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entities="using:SIV.Domain.Entities"
    xmlns:converters="using:SIV.App.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:NullToVisibilityConverter x:Key="InverseNullToVis" Invert="True" />
        <converters:StringToImageSourceConverter x:Key="StringToImageSource" />
        <converters:HexStringToBrushConverter x:Key="HexToBrush" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="8">
            <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                    ToolTipService.ToolTip="Back" Padding="8,4"
                    Command="{x:Bind ViewModel.GoBackCommand}" />
            <TextBlock Text="Preview" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
            <Border CornerRadius="999" Padding="10,4" VerticalAlignment="Center"
                    Background="#0078D4">
                <TextBlock Text="Beta" FontSize="11" FontWeight="SemiBold" Foreground="White" />
            </Border>
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1" Padding="16,0,16,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Weapon List -->
            <Border Grid.Column="0" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Weapon" FontWeight="SemiBold" FontSize="14"
                               Margin="4,0,0,6" />

                    <AutoSuggestBox Grid.Row="1" PlaceholderText="Search weapons"
                                    QueryIcon="Find"
                                    Text="{x:Bind ViewModel.SearchWeaponText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,8" />

                    <ListView Grid.Row="2"
                              ItemsSource="{x:Bind ViewModel.FilteredWeapons, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedWeapon, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entities:WeaponInfo">
                                <TextBlock Text="{x:Bind Name}" Padding="4,6" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Skin List -->
            <Border Grid.Column="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="8"
                    Visibility="{x:Bind ViewModel.SelectedWeapon, Mode=OneWay, Converter={StaticResource NullToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Skin" FontWeight="SemiBold" FontSize="14"
                               Margin="4,0,0,6" />

                    <AutoSuggestBox Grid.Row="1" PlaceholderText="Search skins"
                                    QueryIcon="Find"
                                    Text="{x:Bind ViewModel.SearchSkinText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,0,8" />

                    <ListView Grid.Row="2"
                              ItemsSource="{x:Bind ViewModel.FilteredPaintKits, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedPaintKit, Mode=TwoWay}"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entities:PaintKitInfo">
                                <TextBlock Text="{x:Bind Name}" Padding="4,6" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Preview Panel -->
            <Border Grid.Column="2" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" Padding="16"
                    Visibility="{x:Bind ViewModel.SelectedWeapon, Mode=OneWay, Converter={StaticResource NullToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Item Icon (fills available space) -->
                    <Border Grid.Row="0" CornerRadius="12"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            Margin="0,0,0,16">
                        <Grid>
                            <Image Source="{x:Bind ViewModel.PreviewIconUrl, Mode=OneWay, Converter={StaticResource StringToImageSource}}"
                                   Stretch="Uniform" Margin="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{x:Bind ViewModel.PreviewIconUrl, Mode=OneWay, Converter={StaticResource NullToVis}}" />
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingIcon, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsLoadingIcon, Mode=OneWay}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Info panel (pinned to bottom) -->
                    <StackPanel Grid.Row="1" Spacing="12" MaxWidth="500" HorizontalAlignment="Left">

                        <!-- Item Name -->
                        <TextBlock Text="{x:Bind ViewModel.PreviewName, Mode=OneWay}"
                                   FontWeight="Bold" FontSize="20"
                                   TextWrapping="WrapWholeWords" MaxLines="3" />

                        <!-- Wear slider (disabled, visual only) -->
                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind ViewModel.SelectedPaintKit, Mode=OneWay, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="Wear (Float)" Opacity="0.68" />
                            <!-- Colored wear bar -->
                            <Border CornerRadius="4" Height="8" Margin="0,0,0,4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4CAF50" Offset="0.0" />
                                        <GradientStop Color="#8BC34A" Offset="0.07" />
                                        <GradientStop Color="#8BC34A" Offset="0.15" />
                                        <GradientStop Color="#FFC107" Offset="0.15" />
                                        <GradientStop Color="#FFC107" Offset="0.38" />
                                        <GradientStop Color="#FF9800" Offset="0.38" />
                                        <GradientStop Color="#FF9800" Offset="0.45" />
                                        <GradientStop Color="#F44336" Offset="0.45" />
                                        <GradientStop Color="#F44336" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Minimum="0" Maximum="1"
                                        StepFrequency="0.01"
                                        IsEnabled="False"
                                        Value="{x:Bind ViewModel.Wear, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind ViewModel.WearText, Mode=OneWay}"
                                           VerticalAlignment="Center" FontFamily="Consolas"
                                           Width="50" TextAlignment="Right" />
                            </Grid>
                        </StackPanel>

                        <!-- Seed (disabled) -->
                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind ViewModel.SelectedPaintKit, Mode=OneWay, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="Pattern (Seed)" Opacity="0.68" />
                            <NumberBox Minimum="0" Maximum="999"
                                       SpinButtonPlacementMode="Inline"
                                       SmallChange="1"
                                       IsEnabled="False"
                                       Value="{x:Bind ViewModel.Seed, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- No icon hint -->
                        <InfoBar
                            IsOpen="True"
                            IsClosable="False"
                            Severity="Informational"
                            Title="Icon not available"
                            Message="The icon could not be loaded from the Steam Market."
                            Visibility="{x:Bind ViewModel.ShowIconNotAvailable, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
